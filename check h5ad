import numpy as np

def validate_adata(adata):
    print("===== BASIC SHAPE =====")
    print(f"adata shape: {adata.shape}")
    print(f"obs rows: {adata.n_obs}")
    print(f"var rows: {adata.n_vars}")
    
    print("\n===== INDEX CHECKS =====")
    print("obs_names unique:", adata.obs_names.is_unique)
    print("var_names unique:", adata.var_names.is_unique)
    
    print("\n===== INDEX FORMAT SAMPLE =====")
    print("obs_names sample:", list(adata.obs_names[:5]))
    print("var_names sample:", list(adata.var_names[:5]))
    
    print("\n===== MATRIX CHECK =====")
    print("X type:", type(adata.X))
    try:
        print("X dtype:", adata.X.dtype)
    except:
        print("X dtype: unavailable")
    
    print("\n===== OBS (METADATA) CHECK =====")
    print("obs shape:", adata.obs.shape)
    print("obs columns:", list(adata.obs.columns[:10]))
    
    # Check missing metadata
    missing_fraction = adata.obs.isna().mean().mean()
    print(f"overall missing metadata fraction: {missing_fraction:.4f}")
    
    print("\n===== ALIGNMENT CHECK =====")
    print("obs index matches obs_names:",
          (adata.obs.index == adata.obs_names).all())
    
    print("\n===== SPATIAL CHECK =====")
    if "spatial" in adata.obsm:
        spatial = adata.obsm["spatial"]
        print("spatial shape:", spatial.shape)
        print("spatial matches n_obs:", spatial.shape[0] == adata.n_obs)
        print("spatial sample:", spatial[:5])
    else:
        print("No spatial coordinates found in adata.obsm['spatial']")
    
    print("\n===== DUPLICATE / WEIRD CASES =====")
    dupes = adata.obs_names.duplicated().sum()
    print("duplicate obs_names:", dupes)
    
    print("\n===== QUICK SANITY METRICS =====")
    # sparsity check
    try:
        nnz = adata.X.nnz
        total = adata.n_obs * adata.n_vars
        sparsity = 1 - (nnz / total)
        print(f"sparsity: {sparsity:.4f}")
    except:
        print("sparsity: not sparse or unavailable")
    
    print("\n===== FINAL VERDICT =====")
    
    issues = []
    
    if not adata.obs_names.is_unique:
        issues.append("obs_names not unique")
    if not adata.var_names.is_unique:
        issues.append("var_names not unique")
    if not (adata.obs.index == adata.obs_names).all():
        issues.append("obs not aligned to obs_names")
    if "spatial" in adata.obsm:
        if adata.obsm["spatial"].shape[0] != adata.n_obs:
            issues.append("spatial rows != number of cells")
    
    if issues:
        print("❌ Issues found:")
        for i in issues:
            print(" -", i)
    else:
        print("✅ AnnData structure looks consistent")


# RUN IT
validate_adata(adata)
